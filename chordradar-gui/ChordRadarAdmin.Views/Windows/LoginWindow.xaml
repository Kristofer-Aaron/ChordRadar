<Window x:Class="ChordRadarAdmin.Views.Windows.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="ChordRadar Admin - Login"
    Width="440"
    Height="420"
    Icon="{DynamicResource AppIcon}"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    Background="{DynamicResource BackgroundBrush}"
    Foreground="{DynamicResource ForegroundBrush}">

    <Border Padding="24" Background="{DynamicResource BackgroundBrush}">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="ChordRadar Admin"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"
                       Foreground="{DynamicResource PrimaryBrush}"/>

            <TextBlock Text="Admin Login"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource ErrorBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"/>

            <StackPanel Margin="0,0,0,12">
                <Label Content="Email Address" Style="{StaticResource LabelStyle}"/>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource TextBoxStyle}"/>
            </StackPanel>

            <StackPanel Margin="0,0,0,16">
                <Label Content="Password" Style="{StaticResource LabelStyle}"/>
                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource PasswordBoxStyle}"/>
            </StackPanel>

            <Button Content="Login"
                    Height="40"
                    Command="{Binding LoginCommand}"
                    Style="{StaticResource ButtonStyle}"/>
        </StackPanel>
    </Border>
</Window>
