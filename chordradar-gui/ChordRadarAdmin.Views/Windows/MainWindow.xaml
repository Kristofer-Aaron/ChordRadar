<Window x:Class="ChordRadarAdmin.Views.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="ChordRadar Admin"
    Width="1280"
    Height="800"
    Icon="{DynamicResource AppIcon}"
    WindowStartupLocation="CenterScreen"
    Background="{DynamicResource BackgroundBrush}"
    Foreground="{DynamicResource ForegroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{DynamicResource SecondaryBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="16,20,16,16">
                    <TextBlock Text="ChordRadar"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"/>
                    <TextBlock Text="Admin Panel"
                               FontSize="12"
                               Opacity="0.75"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,8">
                    <Button Content="Chords" Command="{Binding NavigateChordsCommand}" Style="{StaticResource NavButtonStyle}" />
                    <Button Content="Grips" Command="{Binding NavigateGripsCommand}" Style="{StaticResource NavButtonStyle}" />
                    <Button Content="Tunings" Command="{Binding NavigateTuningsCommand}" Style="{StaticResource NavButtonStyle}" />
                    <Button Content="Notations" Command="{Binding NavigateNotationsCommand}" Style="{StaticResource NavButtonStyle}" />
                    <Button Content="Users" Command="{Binding NavigateUsersCommand}" Style="{StaticResource NavButtonStyle}" />
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="16" VerticalAlignment="Bottom">
                    <Button Content="Toggle Theme" Command="{Binding ToggleThemeCommand}" Style="{StaticResource ButtonStyle}" Margin="0,0,0,8" />
                    <Button Content="Logout" Command="{Binding LogoutCommand}" Style="{StaticResource ButtonStyle}" Background="{DynamicResource ErrorBrush}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1" Padding="16">
            <ContentControl Content="{Binding CurrentPage}" />
        </Border>
    </Grid>
</Window>
