<UserControl x:Class="ChordRadarAdmin.Views.Pages.GripsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource SecondaryBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBox Width="280" Margin="0,0,8,0" Style="{StaticResource TextBoxStyle}" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                <Button Content="Clear" Command="{Binding ClearFilterCommand}" Style="{StaticResource ButtonStyle}" Margin="0,0,8,0" />
                <Button Content="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource ButtonStyle}" Margin="0,0,8,0" />
                <Button Content="Add" Command="{Binding AddCommand}" Style="{StaticResource ButtonStyle}" Margin="0,0,8,0" />
                <Button Content="Edit" Command="{Binding EditCommand}" Style="{StaticResource ButtonStyle}" Margin="0,0,8,0" />
                <Button Content="Delete" Command="{Binding DeleteCommand}" Style="{StaticResource ButtonStyle}" Margin="0,0,8,0" Background="{DynamicResource ErrorBrush}" />
                <Button Content="Export" Command="{Binding ExportCommand}" Style="{StaticResource ButtonStyle}" />
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem, Mode=TwoWay}" AutoGenerateColumns="False" IsReadOnly="True" Style="{StaticResource DataGridStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80" />
                <DataGridTextColumn Header="Strings" Binding="{Binding Strings}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
