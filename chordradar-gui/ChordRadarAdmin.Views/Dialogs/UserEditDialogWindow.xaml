<Window x:Class="ChordRadarAdmin.Views.Dialogs.UserEditDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="User Editor"
        Width="420"
        Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}">
    <Border Padding="20">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="User Editor" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" />
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource ErrorBrush}" Margin="0,0,0,8" />

                <TextBlock Text="Username" Margin="0,0,0,4" />
                <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,12" />

                <TextBlock Text="Email Address" Margin="0,0,0,4" />
                <TextBox Text="{Binding EmailAddress, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,12" />

                <StackPanel Margin="0,0,0,12">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsNew}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Password" Margin="0,0,0,4" />
                    <PasswordBox x:Name="PasswordBox" Style="{StaticResource PasswordBoxStyle}" />
                </StackPanel>

                <CheckBox Content="Email Verified" IsChecked="{Binding EmailVerified}" Margin="0,0,0,12" />

                <TextBlock Text="First Name" Margin="0,0,0,4" />
                <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,12" />

                <TextBlock Text="Last Name" Margin="0,0,0,4" />
                <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,12" />

                <TextBlock Text="Role" Margin="0,0,0,4" />
                <ComboBox SelectedValuePath="Content" SelectedValue="{Binding Role, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ComboBoxStyle}" Margin="0,0,0,12">
                    <ComboBoxItem Content="user" />
                    <ComboBoxItem Content="admin" />
                </ComboBox>

                <TextBlock Text="Status" Margin="0,0,0,4" />
                <ComboBox SelectedValuePath="Content" SelectedValue="{Binding Status, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ComboBoxStyle}" Margin="0,0,0,16">
                    <ComboBoxItem Content="active" />
                    <ComboBoxItem Content="pending" />
                    <ComboBoxItem Content="suspended" />
                </ComboBox>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Save" Command="{Binding SaveCommand}" Style="{StaticResource ButtonStyle}" Margin="0,0,8,0" />
                    <Button Content="Cancel" Command="{Binding CancelCommand}" Style="{StaticResource ButtonStyle}" Background="{DynamicResource ErrorBrush}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
