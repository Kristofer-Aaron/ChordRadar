<Window x:Class="ChordRadarAdmin.Views.Dialogs.ExportDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export"
        Width="320"
        Height="220"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}">
    <Border Padding="20">
        <StackPanel>
            <TextBlock Text="Export format" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" />
            <CheckBox Content="CSV" IsChecked="{Binding ExportCsv, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,0,8" />
            <CheckBox Content="JSON" IsChecked="{Binding ExportJson, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,0,16" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="OK" Width="80" Margin="0,0,8,0" Click="Ok_Click" Style="{StaticResource ButtonStyle}" />
                <Button Content="Cancel" Width="80" Click="Cancel_Click" Style="{StaticResource ButtonStyle}" Background="{DynamicResource ErrorBrush}" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
