// DATABASE_URL: mysql://chordRadar:admin@localhost:3306/chord_radar
// $ npx prisma migrate dev --name chord_radar

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Chord {
  id          Int      @id @default(autoincrement())
  notation_id Int
  notation    Notation @relation(fields: [notation_id], references: [id], onDelete: Restrict, onUpdate: Restrict)
  tuning_id   Int
  tuning      Tuning   @relation(fields: [tuning_id], references: [id], onDelete: Restrict, onUpdate: Restrict)
  grip_id     Int
  grip        Grip     @relation(fields: [grip_id], references: [id], onDelete: Restrict, onUpdate: Restrict)

  //Relation to user_chord_relations
  users UserChordRelation[]

  @@map("chords")
}

model Notation {
  id     Int     @id @default(autoincrement())
  value  String  @unique @db.VarChar(16)
  chords Chord[]

  @@map("notations")
}

model Tuning {
  id     Int     @id @default(autoincrement())
  value  String  @unique @db.VarChar(8)
  chords Chord[]

  @@map("tunings")
}

model Grip {
  id      Int     @id @default(autoincrement())
  strings String  @unique @db.VarChar(8)
  chords  Chord[]

  @@map("grips")
}

model User {
  id                  Int              @id @default(autoincrement())
  user_name           String           @db.VarChar(16)
  first_name          String           @db.VarChar(16)
  last_name           String           @db.VarChar(32)
  email_address       String           @unique @db.VarChar(255)
  email_verified      Boolean          @default(false)
  password_hash       String           @db.VarChar(255)
  password_changed_at DateTime
  two_factor_enabled  Boolean          @default(false)
  two_factor_method   TwoFactorMethod?
  two_factor_secret   String?          @db.VarChar(255)
  two_factor_backup   Json?
  role                Role             @default(user)
  status              Status           @default(pending)
  account_created_at  DateTime         @default(now())
  last_login_at       DateTime         @updatedAt
  preferences         Json

  //Relation to user_tokens
  tokens UserToken[]
  //Relation to user_chord_relations
  chords UserChordRelation[]

  @@map("users")
}

enum TwoFactorMethod {
  email
  google_authenticator
  microsoft_authenticator
}

enum Role {
  user
  admin
}

enum Status {
  active
  pending
  suspended
}

model UserToken {
  id         Int       @id @default(autoincrement())
  user_id    Int
  user       User      @relation(fields: [user_id], references: [id], onDelete: Restrict, onUpdate: Restrict)
  token      String    @db.VarChar(255)
  type       TokenType
  created_at DateTime  @default(now())
  expires_at DateTime

  @@map("user_tokens")
}

enum TokenType {
  email_verification
  password_reset
  api_access
}

model UserChordRelation {
  user_id  Int
  user     User  @relation(fields: [user_id], references: [id], onDelete: Restrict, onUpdate: Restrict)
  chord_id Int
  chord    Chord @relation(fields: [chord_id], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@id([user_id, chord_id])
  @@map("user_chord_relations")
}
