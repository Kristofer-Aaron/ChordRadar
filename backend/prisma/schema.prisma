// DATABASE_URL: mysql://chordRadar:admin@localhost:3306/chord_radar
// $ npx prisma migrate dev --name chord_radar

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model chords {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(16)
  tuning_id   Int
  tunings      tunings  @relation(fields: [tuning_id], references: [id], onDelete: Restrict, onUpdate: Restrict)
  grip_id     Int
  grips        grips  @relation(fields: [grip_id], references: [id], onDelete: Restrict, onUpdate: Restrict)
}

model tunings {
  id          Int     @id @default(autoincrement())
  value       String  @unique   @db.VarChar(8)
  chords      chords[]
}

model grips {
  id          Int       @id @default(autoincrement())
  strings     String    @unique   @db.VarChar(8)
  chords      chords[]
}