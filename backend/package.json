{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "description": "NodeJS webserver",
  "main": "server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "npx prisma migrate dev",
    "generate": "npx prisma generate",
    "seed:chords": "node prisma/seeders/chordSeeder.js",
    "seed:users": "node prisma/seeders/testUserSeeder.js",
    "db:setup": "npm run migrate && npm run generate && npm run seed-chords",
    "db:backup": "node src/utils/dbBackup.js"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.15.3",
    "mysqldump": "^1.4.2",
    "nodemailer": "^7.0.10",
    "npm": "^11.10.0",
    "npm-run-path": "^6.0.0",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/npm": "^7.19.3",
    "dotenv": "^17.2.3",
    "nodemon": "^3.1.11",
    "prisma": "^6.18.0"
  }
}
